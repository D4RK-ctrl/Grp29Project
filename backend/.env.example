# Copy to .env and fill in values
DATABASE_URL=postgresql://user:password@host:5432/traveldb

# LLM API configuration (Groq / OpenAI / OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Foursquare Places API (free) — https://location.foursquare.com/developer
FOURSQUARE_API_KEY=

# Yelp Fusion API (free) — https://www.yelp.com/developers
YELP_API_KEY=

# Tavily Search API (free) — https://tavily.com
TAVILY_API_KEY=

# OpenWeatherMap (free) — https://openweathermap.org/api
OPENWEATHER_API_KEY=
